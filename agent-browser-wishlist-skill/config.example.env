# Copy to .env and edit

# Dedicated persistent profile for shopping automation
export AB_PROFILE="$HOME/.agent-browser-profiles/wishlist"

# Default headed mode for bootstrap login. Scheduled jobs may use headless if stable.
export AB_HEADED="--headed"

# Email notification settings (Apple Mail helper)
export ALERT_TO="your_email@example.com"
export ALERT_SUBJECT_PREFIX="[Wishlist Agent]"

# Output directories
export OUTPUT_DIR="$(pwd)/output"
export STATE_DIR="$(pwd)/state"

# Optional extra wait on macOS if agent-browser gets flaky
export AB_EXTRA_WAIT_MS="200"
